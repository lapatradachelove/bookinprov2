          title: currentLang === 'th' ? 'กำลังยกเลิก...' : 'Cancelling...',
          allowOutsideClick: false,
          didOpen: () => {
            Swal.showLoading();
          }
        });

        const deleteResult = await deleteAppointment(apptId);

        if (deleteResult.success) {
          const appt = state.appointments.find(a => a.id === apptId);
          if (appt) {
            const activityDetails = `${appt.visitorName} - ${formatDateToDDMMYYYY(appt.date)} ${formatTimeToHHMM(appt.time)}`;
            await logActivity('appointment_cancelled', activityDetails);
          }

          Swal.close();

          await Swal.fire({
            icon: 'success',
            title: currentLang === 'th' ? 'ยกเลิกสำเร็จ' : 'Cancelled successfully',
            timer: 1500,
            showConfirmButton: false
          });

          await loadAllData();
        } else {
          Swal.close();

          await Swal.fire({
            icon: 'error',
            title: currentLang === 'th' ? 'ยกเลิกไม่สำเร็จ' : 'Cancellation failed',
            confirmButtonColor: '#3261e9'
          });
        }
      }
    }

